<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SlevinthHeavenEliteDangerous.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlevinthHeavenEliteDangerous"
    xmlns:controls="using:SlevinthHeavenEliteDangerous.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SlevinthHeavenEliteDangerous">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Main content area with Tabs -->
        <Grid Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Overlay toggle and optional VoCore enable button — top-right above the tab strip -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,4,12,4"
                            Grid.Row="0"
                            Spacing="8">
                    <Button x:Name="OverlayToggleButton"
                            Content="Open Overlay"
                            Click="OverlayToggleButton_Click" />
                    <Button x:Name="VoCoreToggleButton"
                            Content="Enable VoCore"
                            Click="VoCoreToggleButton_Click"
                            Visibility="Collapsed" />
                </StackPanel>

                <!-- Update available banner -->
                <InfoBar Grid.Row="1"
                         IsOpen="{x:Bind ViewModel.ShowUpdateBanner, Mode=OneWay}"
                         IsClosable="True"
                         Severity="Informational"
                         Title="Update Available"
                         Message="{x:Bind ViewModel.UpdateMessage, Mode=OneWay}" />

                <TabView Grid.Row="2" IsAddTabButtonVisible="False" CanDragTabs="False" CanReorderTabs="False">
                <!-- General Tab -->
                <TabViewItem Header="General" IsClosable="False">
                    <TabViewItem.Content>
                        <controls:GeneralControl x:Name="GeneralControl" />
                    </TabViewItem.Content>
                </TabViewItem>

                <!-- ExoBio Tab -->
                <TabViewItem Header="ExoBio" IsClosable="False">
                    <TabViewItem.Content>
                        <controls:ExoBioControl x:Name="ExoBioControl" />
                    </TabViewItem.Content>
                </TabViewItem>

                <!-- Visited Systems Tab -->
                <TabViewItem Header="Visited Systems" IsClosable="False">
                    <TabViewItem.Content>
                        <controls:VisitedSystemsControl x:Name="VisitedSystemsControl" />
                    </TabViewItem.Content>
                </TabViewItem>

                <!-- Codex Tab -->
                <TabViewItem Header="Codex" IsClosable="False">
                    <TabViewItem.Content>
                        <controls:CodexControl x:Name="CodexControl" />
                    </TabViewItem.Content>
                </TabViewItem>

                <!-- Combat Tab -->
                <TabViewItem Header="Combat" IsClosable="False">
                    <TabViewItem.Content>
                        <controls:CombatControl x:Name="CombatControl" />
                    </TabViewItem.Content>
                </TabViewItem>

                <!-- Frontier Account Tab removed - login is handled at startup -->
                </TabView>
            </Grid>
        </Grid>

        <!-- Loading Overlay - spans both columns -->
        <Grid Grid.ColumnSpan="2" 
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Visibility="{x:Bind ViewModel.IsInitializingVisibility, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Spacing="20"
                        MinWidth="300"
                        CornerRadius="12"
                        Padding="20"
                        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                <ProgressRing IsActive="True" 
                              Width="60" 
                              Height="60"/>
                <TextBlock Text="{x:Bind ViewModel.InitializationMessage, Mode=OneWay}"
                           FontSize="16"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.InitializationProgress, Mode=OneWay}"
                           FontSize="14"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{x:Bind ViewModel.ShowProgressVisibility, Mode=OneWay}"/>
            </StackPanel>
        </Grid>

        <!-- Login Overlay - shown when authentication is required -->
        <Grid Grid.ColumnSpan="2"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
              Visibility="{x:Bind ViewModel.ShowLoginPromptVisibility, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20"
                        MaxWidth="420">
                <TextBlock Text="Slevinth's Elite Dangerous Companion"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="Sign in with your Frontier account to continue."
                           FontSize="14"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <controls:FrontierAuthControl />
            </StackPanel>
        </Grid>

        <!-- Version Block Overlay - shown when app is outdated -->
        <Grid Grid.ColumnSpan="2"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
              Visibility="{x:Bind ViewModel.ShowVersionBlockVisibility, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20"
                        MaxWidth="480">
                <TextBlock Text="Update Required"
                           FontSize="26"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.VersionBlockMessage, Mode=OneWay}"
                           FontSize="14"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:Name="DownloadUpdateButton"
                        Content="Download Latest Version"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Click="DownloadUpdateButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
