<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SlevinthHeavenEliteDangerous.Controls.FSDTargetCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlevinthHeavenEliteDangerous.Controls"
    xmlns:converters="using:SlevinthHeavenEliteDangerous.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
            BorderThickness="1" 
            CornerRadius="8" 
            Padding="16" 
            Margin="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Next System"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="{Binding NextSystem, Mode=OneWay}"
                           FontSize="20"
                           FontWeight="SemiBold"                           
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Spacing="4"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                <TextBlock Text="Jumps Remaining"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Right"/>
                <TextBlock Text="{Binding RemainingJumpsFormatted, Mode=OneWay}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                           HorizontalAlignment="Right"
                           FontFamily="Consolas"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        Spacing="4"
                        Visibility="{Binding HasFinalDestination, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="Destination"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="{Binding FinalDestination, Mode=OneWay}"
                           FontSize="20"
                           FontWeight="SemiBold"                           
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
    