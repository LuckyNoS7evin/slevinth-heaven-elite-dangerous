<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SlevinthHeavenEliteDangerous.Controls.OverlayLogControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlevinthHeavenEliteDangerous.Controls"
    xmlns:vm="using:SlevinthHeavenEliteDangerous.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="#CC111820"
            CornerRadius="8"
            Padding="10">
        <StackPanel Spacing="6">

            <!-- Header -->
            <TextBlock Text="SCAN LOG"
                       FontSize="11"
                       FontWeight="SemiBold"
                       CharacterSpacing="100"
                       Foreground="#FF8899AA"
                       Margin="0,0,0,4"/>

            <!-- Log entries -->
            <ScrollViewer x:Name="LogScrollViewer"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="LogItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:OverlayLogEntry">
                            <Grid Margin="0,0,0,6" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Time + type indicator -->
                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Top">
                                    <TextBlock Text="{x:Bind TimeText}"
                                               FontSize="10"
                                               Foreground="#FF8899AA"
                                               FontFamily="Consolas"/>
                                    <Border Width="3"
                                            Height="3"
                                            CornerRadius="2"
                                            HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Title + subtext -->
                                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Top">
                                    <TextBlock Text="{x:Bind Title}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#FFEEF0F4"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind SubText}"
                                               FontSize="10"
                                               Foreground="#FF8899AA"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Value -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind ValueText}"
                                           FontSize="11"
                                           FontFamily="Consolas"
                                           Foreground="#FF4EC994"
                                           VerticalAlignment="Top"
                                           TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </StackPanel>
    </Border>
</UserControl>
