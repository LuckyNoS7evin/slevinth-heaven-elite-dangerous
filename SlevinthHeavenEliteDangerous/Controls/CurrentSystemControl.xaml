<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SlevinthHeavenEliteDangerous.Controls.CurrentSystemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:SlevinthHeavenEliteDangerous.ViewModels"
    xmlns:converters="using:SlevinthHeavenEliteDangerous.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:TerraformToVisibilityConverter x:Key="TerraformToVisibilityConverter"/>
        <converters:TextToColourConverter x:Key="TextToColourConverter"/>
    </UserControl.Resources>

    <Grid Visibility="{Binding HasCurrentSystem, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="1" 
                CornerRadius="8,8,0,0" 
                Padding="12"
                Margin="4,12,12,0">
            <StackPanel Spacing="4">
                <TextBlock Text="Current System" 
                           FontSize="16" 
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SystemName, Mode=OneWay}" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <TextBlock Text="{Binding ValuableBodiesCount, Mode=OneWay}" 
                           FontSize="12" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Valuable Bodies List -->
        <ScrollViewer Grid.Row="1" Margin="4,4,12,12">
            <ItemsControl ItemsSource="{Binding ValuableBodies, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:BodyCardViewModel">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1,0,1,1" 
                                Padding="12">
                            <StackPanel Spacing="6">
                                <!-- Body Name and Class -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{x:Bind BodyName}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind PlanetClass}" 
                                               FontSize="12" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Badges -->
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <!-- Landable Badge -->
                                    <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            Visibility="{x:Bind Landable, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="LANDABLE"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>

                                    <!-- Terraformable Badge -->
                                    <Border Background="{ThemeResource SystemFillColorCautionBrush}"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            Visibility="{x:Bind TerraformState, Converter={StaticResource TerraformToVisibilityConverter}}">
                                        <TextBlock Text="TERRAFORMABLE"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>

                                     <!-- Biological Badge -->
                                     <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                             CornerRadius="3"
                                             Padding="6,2"
                                             Visibility="{x:Bind HasBiologicalSignals, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                         <TextBlock Text="{x:Bind BiologicalSignalsBadgeText, Mode=OneWay}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"/>
                                     </Border>
                                </StackPanel>

                                <!-- Distance and Discovery Status -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind DistanceFromArrivalFormatted}" 
                                               FontSize="12" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind DiscoveryStatus}" 
                                               FontSize="12" 
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
