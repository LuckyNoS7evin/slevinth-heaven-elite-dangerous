<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SlevinthHeavenEliteDangerous.Controls.CommanderStatsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlevinthHeavenEliteDangerous.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <TextBlock Text="Commander Stats" 
                   FontSize="20" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,12"/>

        <StackPanel Spacing="8" Grid.Row="1">

            <!-- Bank Account -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Bank Account" FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Current Wealth" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding CurrentWealthFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Ships Owned" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding OwnedShipCount, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Exploration -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Exploration" FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Systems Visited" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding SystemsVisitedFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Hyperspace Jumps" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalHyperspaceJumpsFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="Distance Travelled" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalHyperspaceDistanceFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock Text="Exploration Profits" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding ExplorationProfitsFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="2">
                            <TextBlock Text="Time Played" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding TimePlayedFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Trading / Combat / Mining / Exobiology -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Trading -->
                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,4,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Trading" FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Market Profits" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding MarketProfitsFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Markets Traded With" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding MarketsTradedWith, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Combat -->
                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="4,0,4,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Combat" FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Bounty Hunting Profit" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding BountyHuntingProfitFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Bounties Claimed" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding BountiesClaimedFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Mining -->
                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="4,0,4,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Mining" FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Mining Profits" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding MiningProfitsFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Exobiology -->
                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="4,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Exobiology" FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Exobiology Profits" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding ExobiologyProfitsFormatted, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Species Analysed" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding OrganicSpeciesAnalysed, Mode=OneWay}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </Grid>
</UserControl>
