<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SlevinthHeavenEliteDangerous.Controls.ReputationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:SlevinthHeavenEliteDangerous.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Faction Reputation"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- Faction Cards -->
        <GridView Grid.Row="1"
                  ItemsSource="{Binding Factions, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:FactionReputationViewModel">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            MinWidth="250"
                            MinHeight="180"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Faction Name -->
                            <TextBlock Grid.Row="0"
                                       Text="{x:Bind FactionName}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                            <!-- Status Label and Value -->
                            <StackPanel Grid.Row="1"
                                        Spacing="4"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind StatusLabel, Mode=OneWay}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ValueFormatted, Mode=OneWay}"
                                           FontSize="14"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Progress Bar -->
                            <ProgressBar Grid.Row="2"
                                         Value="{x:Bind BarValue, Mode=OneWay}"
                                         Maximum="100"
                                         Height="12"
                                         MinHeight="12"
                                         CornerRadius="6"
                                         Background="{ThemeResource LayerFillColorDefaultBrush}"
                                         Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   MaximumRowsOrColumns="4"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>
    </Grid>
</UserControl>
