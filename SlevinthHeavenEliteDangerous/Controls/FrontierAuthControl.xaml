<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SlevinthHeavenEliteDangerous.Controls.FrontierAuthControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlevinthHeavenEliteDangerous.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Frontier Account"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Spacing="12">

            <!-- Auth Status Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Authentication Status" FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <!-- Logged-in state -->
                    <StackPanel Spacing="8"
                                Visibility="{Binding IsAuthenticated, Mode=OneWay}">
                        <TextBlock Text="{Binding CommanderNameFormatted, Mode=OneWay}"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="{Binding Status, Mode=OneWay}"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Button Content="Logout"
                                Click="LogoutButton_Click"
                                IsEnabled="{Binding IsNotBusy, Mode=OneWay}"/>
                    </StackPanel>

                    <!-- Logged-out state -->
                    <StackPanel Spacing="8"
                                Visibility="{Binding IsNotAuthenticated, Mode=OneWay}">
                        <TextBlock Text="{Binding Status, Mode=OneWay}"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Login with Frontier"
                                    Click="LoginButton_Click"
                                    IsEnabled="{Binding IsNotBusy, Mode=OneWay}"
                                    Style="{ThemeResource AccentButtonStyle}"/>
                            <ProgressRing IsActive="{Binding IsBusy, Mode=OneWay}"
                                          Width="24" Height="24"
                                          VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap">
                            Logging in will open your browser to the Frontier authorisation page.
                            Your credentials are never seen by this app.
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
