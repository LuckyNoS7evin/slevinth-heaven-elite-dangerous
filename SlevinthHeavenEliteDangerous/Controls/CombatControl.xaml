<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SlevinthHeavenEliteDangerous.Controls.CombatControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:SlevinthHeavenEliteDangerous.ViewModels"
    xmlns:converters="using:SlevinthHeavenEliteDangerous.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibility"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </UserControl.Resources>

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="Combat Log"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- ── Main body: left stats panel + right kill log ───────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Stats + Rank Estimation ─────────────────────────── -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">

                    <!-- Kill Counts -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Kills"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding NpcKillCount, Mode=OneWay}"
                                               FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="NPC" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding PvpKillCount, Mode=OneWay}"
                                               FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="PVP" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding TotalKillCount, Mode=OneWay}"
                                               FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Total" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Earnings -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Earnings"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid ColumnSpacing="8" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="1"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Bounties" FontSize="13"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding TotalBountyCreditsFormatted, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Combat Bonds" FontSize="13"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding TotalCombatBondCreditsFormatted, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Cap Ship Bonds" FontSize="13"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding TotalCapShipBondCreditsFormatted, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>

                                <Rectangle Grid.Row="3" Grid.ColumnSpan="2"
                                           Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                           Margin="0,2"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Total" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="4" Grid.Column="1"
                                           Text="{Binding TotalCombatEarningsFormatted, Mode=OneWay}"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Combat Stats: Deaths, Hull, Crimes -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Combat Stats"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid ColumnSpacing="8" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Deaths" FontSize="13"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DeathCount, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Hull Low Mark" FontSize="13"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding HullLowWaterMarkFormatted, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Crimes" FontSize="13"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding CrimeCount, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Interdictions -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Interdictions"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid ColumnSpacing="8" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="You interdicted" FontSize="13"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding InterdictionsAttempted, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="  — succeeded" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding InterdictionsSucceeded, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Interdicted by" FontSize="13"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding TimesInterdicted, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="  — escaped" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{Binding InterdictionsEscaped, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Kills-to-Next-Rank Estimation (hidden when Elite) -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Visibility="{Binding IsAtMaxRank, Mode=OneWay, Converter={StaticResource BoolToInverseVisibility}}">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="Kills to "/>
                                <Run Text="{Binding NextRankName, Mode=OneWay}"
                                     Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            </TextBlock>
                            <TextBlock FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{Binding CombatRankName, Mode=OneWay}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding CombatRankProgressFormatted, Mode=OneWay}"/>
                                <Run Text=" progress"/>
                            </TextBlock>

                            <!-- Estimate table -->
                            <Grid ColumnSpacing="8" RowSpacing="4" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="vs +2 rank (2× XP)" FontSize="13"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding KillsEstimatePlus2, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="vs +1 rank (1.5× XP)" FontSize="13"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding KillsEstimatePlus1, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="vs equal rank (1× XP)" FontSize="13"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding KillsEstimateEqual, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="vs −1 rank (0.5× XP)" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{Binding KillsEstimateMinus1, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="vs −2 rank (0.25× XP)" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1"
                                           Text="{Binding KillsEstimateMinus2, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                            <TextBlock Text="* community-approximated values"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Top Factions by Kill Count -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Top Factions"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ItemsControl ItemsSource="{Binding TopFactions, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:FactionKillViewModel">
                                        <Grid ColumnSpacing="8" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Faction}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind KillCount}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── RIGHT: Kill Log ──────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Kill Log"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8"/>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding KillLog, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:CombatKillEntryViewModel">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,7"
                                    Margin="0,2">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Kill type badge -->
                                    <Border Grid.Column="0"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind KillTypeBadge}"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>

                                    <!-- Target + faction + rank -->
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Target}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind VictimFaction}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{x:Bind VictimFaction, Converter={StaticResource StringToVisibility}}"/>
                                            <TextBlock Text="{x:Bind VictimRankName}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                       Visibility="{x:Bind VictimRankName, Converter={StaticResource StringToVisibility}}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Credits + timestamp -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Spacing="1">
                                        <TextBlock Text="{x:Bind CreditsEarnedFormatted}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                   HorizontalAlignment="Right"
                                                   Visibility="{x:Bind CreditsEarnedFormatted, Converter={StaticResource StringToVisibility}}"/>
                                        <TextBlock Text="{x:Bind TimestampFormatted}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
